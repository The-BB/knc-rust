--- a/Cargo.toml
+++ b/Cargo.toml
@@ -73,7 +73,7 @@ bytes = "1"
 bytesize = "1.3.3"
 calamine = "0.27"
 chardetng = "0.1.17"
-chrono = { default-features = false, version = "0.4.34" }
+chrono = { default-features = false, version = "=0.4.40" }
 chrono-humanize = "0.2.3"
 chrono-tz = "0.10"
 crossbeam-channel = "0.5.8"
@@ -136,7 +136,8 @@ quickcheck = "1.0"
 quickcheck_macros = "1.0"
 quote = "1.0"
 rand = "0.9"
-getrandom = "0.2" # pick same version that rand requires
+# all: no SYS_getrandom
+getrandom = "=0.2.15" # pick same version that rand requires
 rand_chacha = "0.9"
 ratatui = "0.29"
 rayon = "1.10"
@@ -328,6 +331,16 @@ bench = false
 
 # Run all benchmarks with `cargo bench`
 # Run individual benchmarks like `cargo bench -- <regex>` e.g. `cargo bench -- parse`
+
+# localtime/zoneinfo
+chrono = { path = "../chrono-0.4.40" }
+iana-time-zone = { path = "../iana-time-zone-0.1.61" }
+# openssl
+openssl-probe = { path = "../openssl-probe-0.1.5" }
+# all: no SYS_getrandom
+getrandom2 = { path = "../getrandom-0.2.15", package = "getrandom", version = "0.2.15" }
+getrandom3 = { path = "../getrandom-0.3.1", package = "getrandom", version = "0.3.1" }
+
 [[bench]]
 name = "benchmarks"
 harness = false
